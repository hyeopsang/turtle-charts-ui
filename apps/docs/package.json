{
  "name": "docs",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build --docs",
    "preview-storybook": "serve storybook-static",
    "lint": "eslint ./stories/*.stories.tsx --max-warnings 0",
    "clean": "rm -rf .turbo node_modules storybook-static"
  },
  "dependencies": {
    "@turtle/ui": "workspace:*",
    "@types/node": "^25.3.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/react": "^10.2.14",
    "@storybook/react-vite": "^10.2.14",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "serve": "^14.2.1",
    "storybook": "^10.2.14",
    "tailwindcss": "^4.2.1",
    "typescript": "5.5.4",
    "vite": "^5.1.4"
  },
  "pnpm": {
    "overrides": {
      "storybook": "10.2.13",
      "@storybook/*": "10.2.13"
    }
  }
